# PostgreSQL (Railway lo provee automáticamente)
DATABASE_URL=postgresql://usuario:password@host:5432/database

# Firebase Admin (pega el JSON del service account como string)
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# O solo el project ID para desarrollo local
FIREBASE_PROJECT_ID=tu-proyecto-firebase

# Puerto (Railway lo asigna automáticamente)
PORT=3000

# Entorno
NODE_ENV=production

# URL del frontend (para CORS)
FRONTEND_URL=https://tu-app.railway.app

# RUT del empleador para PreviRed
RUT_EMPLEADOR=00.000.000-0
